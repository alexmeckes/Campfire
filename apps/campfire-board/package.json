{
  "name": "campfire-board",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c \"bgRed.bold,bgYellow.bold\" \"npm:dev:server\" \"npm:dev:web\"",
    "dev:desktop": "concurrently -n api,web,desktop -c \"bgRed.bold,bgYellow.bold,bgBlue.bold\" \"npm:dev:server\" \"npm:dev:web\" \"npm:electron:dev\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "npm run build:web && npm run build:server",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "test:smoke": "npm run build && node scripts/electron-smoke.mjs",
    "preview": "vite preview",
    "start": "node dist/server/server/index.js",
    "desktop": "concurrently -n api,desktop -c \"bgRed.bold,bgBlue.bold\" \"npm:start\" \"npm:electron\"",
    "electron": "wait-on http://127.0.0.1:4319 && electron electron/main.mjs",
    "electron:dev": "wait-on http://127.0.0.1:4173 && CAMPFIRE_BOARD_DESKTOP_URL=http://127.0.0.1:4173 electron electron/main.mjs"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.0",
    "electron": "^30.5.1",
    "playwright": "^1.58.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "wait-on": "^8.0.1"
  }
}
